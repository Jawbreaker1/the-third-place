{
  "name": "the-third-place",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A living AI community with local LM Studio inference, an experimental Codex subscription provider, and a deterministic social director.",
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"tsx watch server/index.ts\" \"vite --host 0.0.0.0\"",
    "dev:voice": "concurrently -k -n tts,app -c magenta,cyan \"npm run start:tts\" \"npm run dev\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "NODE_ENV=production node dist-server/server/index.js",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "lm:check": "node scripts/lm-check.mjs",
    "smoke:e2e": "node scripts/e2e-smoke.mjs",
    "smoke:voice": "node scripts/voice-smoke.mjs",
    "setup:tts": "node scripts/setup-piper-tts.mjs",
    "prestart:tts": "npm run setup:tts",
    "start:tts": "node scripts/start-piper-tts.mjs",
    "test:tts-sidecar": "node --test scripts/piper-tts-setup.node-test.mjs && python3 -m unittest scripts.tts.test_piper_sidecar",
    "smoke:image": "node scripts/image-smoke.mjs",
    "smoke:research": "node scripts/research-smoke.mjs",
    "smoke:history-links": "node scripts/history-link-smoke.mjs",
    "audit:humanity": "node scripts/humanity-audit.mjs",
    "eval:humanity": "node --import tsx scripts/humanity-live-eval.mjs",
    "eval:semantics": "node --import tsx scripts/semantic-router-live-eval.mjs",
    "test:audit:humanity": "node --test scripts/humanity-audit.node-test.mjs"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ipaddr.js": "^2.4.0",
    "parse5": "^8.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tldts": "^7.4.8",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
