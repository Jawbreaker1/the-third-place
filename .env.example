# Web server. It binds to all interfaces so LAN users and HTTPS tunnels can connect.
PORT=4000
# 127.0.0.1 is safest with a Cloudflare Tunnel. Use 0.0.0.0 for direct LAN access.
HOST=127.0.0.1
# Exact absolute http(s) origin only (for example an HTTPS ngrok URL). Paths,
# credentials, queries, fragments and non-HTTP schemes fail startup.
PUBLIC_ORIGIN=
# Enable only behind a trusted reverse proxy/tunnel that provides the client IP.
TRUST_PROXY=false

# Optional invite gate for a public demo. Leave blank for an open room.
ROOM_INVITE_CODE=

# Comma-separated exact http(s) browser origins allowed to connect. Each
# non-empty entry is validated at startup. Leaving both this and PUBLIC_ORIGIN
# blank enables the deliberately open browser-origin mode for local development.
ALLOWED_ORIGINS=

# Optional live administration. There is deliberately no default password;
# leaving this blank disables admin login. A configured password must contain
# at least 12 characters or startup fails. The raw password and admin session
# token are never persisted. Keep the state file outside public static assets.
ADMIN_PASSWORD=
ADMIN_STATE_PATH=./data/admin-state.json
# Temporary reconnect cooldown after an admin kick (bounded server-side).
ADMIN_KICK_COOLDOWN_MS=300000

# Active dialogue provider. Admin changes are persisted separately and take
# precedence after the first live switch. Neither choice exposes credentials
# to browser clients.
LLM_PROVIDER=lmstudio
LLM_PROVIDER_STATE_PATH=./data/llm-provider.json

# LM Studio stays private on the same machine as this server.
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=google/gemma-4-26b-a4b
# LM Studio 0.4+ token, only if you enabled authentication in Developer settings.
LM_STUDIO_API_TOKEN=
LM_STUDIO_TIMEOUT_MS=90000
# Gemma 4 may spend several hundred tokens in reasoning before emitting JSON.
# 0/blank uses the app's dynamic 1500–2100 token budget.
LM_STUDIO_MAX_TOKENS=

# Experimental ChatGPT-subscription provider through a hardened local Codex
# app-server wrapper. The admin page uses official device-code login; never put
# a ChatGPT password, cookie, access token or API key in this file.
# On macOS the server prefers ChatGPT.app's bundled, current Codex binary before
# PATH. Set an explicit absolute path only when auto-discovery is unsuitable.
CODEX_CLI_PATH=
CODEX_MODEL=gpt-5.6-luna
CODEX_WRAPPER_HOME=./data/codex-home
# Blank uses an isolated OS temporary directory outside the repository.
CODEX_RUNTIME_PATH=
CODEX_TIMEOUT_MS=120000
# One social scene may use generation plus semantic review/repair turns.
CODEX_MAX_TURNS_PER_MINUTE=24
CODEX_MAX_TURNS_PER_DAY=1200
# Atomically persisted daily counter; contains no authentication material.
CODEX_BUDGET_STATE_PATH=./data/codex-budget.json

# Residents share the server's local clock for subtle daypart awareness and
# elapsed-time context. Leave blank to use the host OS IANA time zone.
COMMUNITY_TIME_ZONE=
# Optional friendly label shown only to the model (for example The Third Place).
COMMUNITY_LOCATION_LABEL=

# calm | lively | party. "lively" is the public-demo default.
AI_PACE=lively
# Set to false to keep the UI running entirely on deterministic fallback lines.
AI_ENABLED=true
# Probability (0..1) of attempting a rare deeper two-resident thread on an
# otherwise eligible ambient tick. Hard gates still require 75 s of human quiet,
# an empty model queue, spare message budget, no voice room and a global 6 min cooldown.
AI_CONSIDERED_CHANCE=0.20
# High-severity repetition/AI-meta/style failures share at most one repair call
# per human event. Set false to validate and drop without the extra model call.
HUMANIZER_REPAIR_ENABLED=true

# Human-started, small-room WebRTC voice. Browser capture uses standards-based
# getUserMedia/MediaRecorder; HTTPS (or localhost) is required for microphone access.
VOICE_ENABLED=true
VOICE_RECONNECT_GRACE_MS=15000
# JSON array of RTCIceServer objects. Public STUN is the development fallback.
# Add credentials for your own TURN service before relying on external/mobile users:
# VOICE_ICE_SERVERS_JSON=[{"urls":["stun:stun.example.com:3478","turn:turn.example.com:3478?transport=udp","turn:turn.example.com:3478?transport=tcp"],"username":"demo","credential":"replace-me"}]
VOICE_ICE_SERVERS_JSON=
# Browser speechSynthesis is a disclosed fallback when no server TTS is configured.
# The server includes this policy in every AI speech event; clients must obey it.
VOICE_BROWSER_FALLBACK=true

# Optional OpenAI-compatible speech-to-text endpoint. Gemma remains the dialogue
# model; it does not transcribe audio. ffmpeg + ffprobe are required when enabled.
STT_ENABLED=true
STT_BASE_URL=
STT_API_KEY=
STT_MODEL=
STT_TIMEOUT_MS=30000
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Optional OpenAI-compatible text-to-speech endpoint. These defaults target the
# repo-owned local Piper sidecar (`npm run start:tts`) on loopback port 8179.
# Without it, AI replies remain visible and can use the disclosed browser fallback.
TTS_ENABLED=true
TTS_BASE_URL=http://127.0.0.1:8179/v1
TTS_API_KEY=
TTS_MODEL=piper-sv
TTS_VOICE=lisa-warm
# Comma-separated provider voice IDs an admin may map to languages. For the
# bundled piper-sv model the fixed local voice list is used instead. Generic
# providers expose only this allowlist plus TTS_VOICE, never API credentials.
TTS_VOICES=
# Generic TTS providers are default-deny: list the BCP-47 language ranges that
# the configured model/voice can actually speak (for example en,fr,zh-Hant).
# Empty disables generic server TTS. The bundled piper-sv model is always
# restricted to sv regardless of this value.
TTS_LANGUAGES=sv
TTS_FORMAT=wav
TTS_TIMEOUT_MS=30000
TTS_AUDIO_TTL_MS=60000

# Local Piper sidecar. The bind address is intentionally fixed to 127.0.0.1;
# ngrok guests receive audio through the authenticated application route only.
PIPER_TTS_PORT=8179
PIPER_TTS_CACHE_DIR=.cache/piper-tts
PIPER_TTS_VENV_DIR=.venv-tts
PIPER_TTS_BOOTSTRAP_PYTHON=3.11
# Optional defense in depth on the loopback HTTP hop. If set, TTS_API_KEY must
# carry the same value in the Node application.
PIPER_TTS_API_KEY=

# Typed seven-day weather for explicitly classified named locations. This is
# enabled unless set to the exact value false. The bounded location query is
# sent server-side to Open-Meteo geocoding and forecast APIs; Open-Meteo sees
# the application server IP. This is independent of RESEARCH_ENABLED.
WEATHER_ENABLED=true

# Typed fixtures, latest-reported results and provisional group standings for
# the fixed FIFA_WC_2026 competition catalog. The bundled keyless development
# source is community-updated within hours after full time, not minute-by-minute
# live data. It sees the application server IP and is independent of generic
# research. Enabled unless set to the exact value false.
FOOTBALL_DATA_ENABLED=true

# Provider-neutral latest-reported snapshots for a fixed catalog of major
# global headline equity indexes and four bounded regional/global baskets.
# This is benchmark coverage, not every exchange, security, fund or company.
# The bundled fixed-host Yahoo chart adapter is experimental and undocumented;
# use a provider with explicit display/licensing rights for a public deployment.
# Enabled unless set to the exact value false. Independent of generic search.
MARKET_SNAPSHOT_ENABLED=true

# Fixed-source MarketPulse for #stock-market. It can poll allowlisted official
# Fed, ECB, SEC and Riksbank feeds and detect exceptional moves from validated
# market snapshots. Publication still requires RESEARCH_ENABLED=true,
# AUTONOMOUS_RESEARCH_ENABLED=true and a non-zero Admin AI-posted-links control;
# selected feed articles must survive the normal safe full-page reader.
# Enabled unless set to the exact value false. The atomic state stores only
# feed validators, bounded dedupe keys, movement high-water marks and timings.
MARKET_PULSE_ENABLED=true
MARKET_PULSE_STATE_PATH=./data/market-pulse-state.json

# Experimental. Uses bounded Bing RSS for explicitly classified current-
# information requests and, when enabled below, rare server-owned room subjects.
# Generic results must survive bounded page expansion before they are answerable;
# a failed guest exact-page read never becomes a search fallback.
# Review the provider terms for your use case before enabling publicly.
RESEARCH_ENABLED=false

# When research is enabled, allow a very rare server-owned room-topic lookup.
# It still requires long human quiet, a fresh ambient thread, two free message
# slots, daily/global/per-room cooldowns and a safely readable public page.
AUTONOMOUS_RESEARCH_ENABLED=false

# Fetches text-only metadata for the first public HTTPS link in a human message.
# The destination site sees the server's IP. Private/local addresses are blocked.
LINK_PREVIEWS_ENABLED=true

# Lets residents read one bounded public HTTPS page after an explicit request.
# Disable to prevent arbitrary page fetches.
LINK_READER_ENABLED=true

# Optional low-priority social reaction to the first safe link in a new public
# human message. Successful reads get one grounded resident comment; failed
# reads stay silent. Separate hard cooldowns keep this from becoming a crawler.
AUTO_DISCUSS_SHARED_LINKS=false

# Optional override, useful for isolated smoke tests.
ROOM_STATE_PATH=./data/room-state.json
# Pseudonymous return visits, bounded public-text facts and per-persona rapport.
# Only token hashes are persisted; the raw token travels as an HttpOnly browser cookie.
HUMAN_MEMORY_PATH=./data/human-memory.json
# Sanitized WebP originals and thumbnails. Never point this at a public static folder.
IMAGE_STORE_PATH=./data/images
