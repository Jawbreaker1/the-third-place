# Web server. It binds to all interfaces so LAN users and HTTPS tunnels can connect.
PORT=4000
# 127.0.0.1 is safest with a Cloudflare Tunnel. Use 0.0.0.0 for direct LAN access.
HOST=127.0.0.1
PUBLIC_ORIGIN=
# Enable only behind a trusted reverse proxy/tunnel that provides the client IP.
TRUST_PROXY=false

# Optional invite gate for a public demo. Leave blank for an open room.
ROOM_INVITE_CODE=

# Comma-separated browser origins allowed to connect. Leave blank to accept the
# same origin (production) and local Vite dev origins.
ALLOWED_ORIGINS=

# LM Studio stays private on the same machine as this server.
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=google/gemma-4-26b-a4b
# LM Studio 0.4+ token, only if you enabled authentication in Developer settings.
LM_STUDIO_API_TOKEN=
LM_STUDIO_TIMEOUT_MS=90000
# Gemma 4 may spend several hundred tokens in reasoning before emitting JSON.
# 0/blank uses the app's dynamic 1500–2100 token budget.
LM_STUDIO_MAX_TOKENS=

# calm | lively | party. "lively" is the public-demo default.
AI_PACE=lively
# Set to false to keep the UI running entirely on deterministic fallback lines.
AI_ENABLED=true
# Probability (0..1) of attempting a rare deeper two-resident thread on an
# otherwise eligible ambient tick. Hard gates still require 75 s of human quiet,
# an empty model queue, spare message budget, no voice room and a global 10 min cooldown.
AI_CONSIDERED_CHANCE=0.10
# High-severity repetition/AI-meta/style failures share at most one repair call
# per human event. Set false to validate and drop without the extra model call.
HUMANIZER_REPAIR_ENABLED=true

# Human-started, small-room WebRTC voice. Browser capture uses standards-based
# getUserMedia/MediaRecorder; HTTPS (or localhost) is required for microphone access.
VOICE_ENABLED=true
VOICE_RECONNECT_GRACE_MS=15000
# JSON array of RTCIceServer objects. Public STUN is the development fallback.
# Add credentials for your own TURN service before relying on external/mobile users:
# VOICE_ICE_SERVERS_JSON=[{"urls":["stun:stun.example.com:3478","turn:turn.example.com:3478?transport=udp","turn:turn.example.com:3478?transport=tcp"],"username":"demo","credential":"replace-me"}]
VOICE_ICE_SERVERS_JSON=
# Browser speechSynthesis is a disclosed fallback when no server TTS is configured.
VOICE_BROWSER_FALLBACK=true

# Optional OpenAI-compatible speech-to-text endpoint. Gemma remains the dialogue
# model; it does not transcribe audio. ffmpeg + ffprobe are required when enabled.
STT_ENABLED=true
STT_BASE_URL=
STT_API_KEY=
STT_MODEL=
STT_TIMEOUT_MS=30000
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Optional OpenAI-compatible text-to-speech endpoint. Without it, AI replies are
# still visible and can be spoken by each browser's clearly labelled fallback voice.
TTS_ENABLED=true
TTS_BASE_URL=
TTS_API_KEY=
TTS_MODEL=
TTS_VOICE=
TTS_FORMAT=mp3
TTS_TIMEOUT_MS=30000
TTS_AUDIO_TTL_MS=60000

# Experimental. Uses Bing RSS snippets for explicit/current-info requests.
# Review the provider terms for your use case before enabling publicly.
RESEARCH_ENABLED=false

# Fetches text-only metadata for the first public HTTPS link in a human message.
# The destination site sees the server's IP. Private/local addresses are blocked.
LINK_PREVIEWS_ENABLED=true

# Optional override, useful for isolated smoke tests.
ROOM_STATE_PATH=./data/room-state.json
# Pseudonymous return visits, bounded public-text facts and per-persona rapport.
# Only token hashes are persisted; the raw token travels as an HttpOnly browser cookie.
HUMAN_MEMORY_PATH=./data/human-memory.json
# Sanitized WebP originals and thumbnails. Never point this at a public static folder.
IMAGE_STORE_PATH=./data/images
